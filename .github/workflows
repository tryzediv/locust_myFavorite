name: Простой CI-воркфлоу

on:
  push:
    branches:
      - '*'

jobs:
  first_job:
    runs-on: ubuntu-latest
    steps:
      - name: Приветствие
        run: echo "Запущен первый этап"
      - name: Информация о системе
        run: echo "Система - Ubuntu 20.04"
      - name: Рисуем кота
        run: |
          echo "   /\_/\\"
          echo "  ( o.o )"
          echo "  > ^ <"
          echo "Кот первой джобы приветствует вас!"
  
  second_job:
    runs-on: ubuntu-latest
    steps:
      - name: Старт тестирования
        run: echo "Тестирование начато"
      - name: Проверка завершена
        run: echo "Все проверки успешны"
      - name: Рисуем танцующего кота
        run: |
          echo "  /\_/\\  "
          echo " (='_' ) "
          echo " (,\")(\") "
          echo "Танцующий кот второй джобы празднует успех!"
